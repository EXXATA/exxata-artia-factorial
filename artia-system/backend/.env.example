# Server Configuration
PORT=3000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Microsoft corporate access policy
MICROSOFT_ALLOWED_DOMAIN=exxata.com.br
MICROSOFT_ALLOWED_TENANT_ID=

# Artia Database (MySQL/ODBC)
ARTIA_DB_HOST=localhost
ARTIA_DB_PORT=3306
ARTIA_DB_USER=artia_user
ARTIA_DB_PASSWORD=artia_password
ARTIA_DB_NAME=artia_database

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Redis (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# File Upload
MAX_FILE_SIZE=10485760

# Factorial API
FACTORIAL_API_KEY=your-factorial-api-key-here
FACTORIAL_API_URL=https://api.factorialhr.com
