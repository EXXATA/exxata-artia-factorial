{
  "name": "artia-backend",
  "version": "1.0.0",
  "description": "Backend API para sistema de apontamento de horas Artia",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "dev:local": "node src/server.js",
    "setup": "node scripts/setup.js",
    "generate-secrets": "node ../scripts/generate-secrets.js",
    "vercel-build": "echo 'Build complete'",
    "test": "jest",
    "test:auth-flow": "node --test tests/unit/RegisterWithFactorialUseCase.test.js",
    "test:microsoft-auth": "node --test --test-isolation=none tests/unit/CorporateMicrosoftIdentityPolicy.test.js tests/unit/ResolveAuthenticatedUserUseCase.test.js",
    "test:andre-analysis": "node scripts/analyze-user-functional.js andre.baptista@exxata.com.br 30",
    "test:andre-http-flows": "node scripts/check-user-http-flows.js andre.baptista@exxata.com.br",
    "reconcile:auth-users": "node scripts/reconcile-auth-users.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "artia",
    "timesheet",
    "ddd",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.19.0",
    "socket.io": "^4.6.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  }
}
