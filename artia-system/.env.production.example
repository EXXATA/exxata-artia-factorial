# Backend Production Environment Variables (Vercel)

NODE_ENV=production

# MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/artia?retryWrites=true&w=majority

# JWT Secrets (MUDE ESTES VALORES!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# CORS (URL do frontend na Vercel)
CORS_ORIGIN=https://your-frontend.vercel.app

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Frontend Production Environment Variables (Vercel)

# API URL (URL do backend na Vercel)
VITE_API_URL=https://your-backend.vercel.app/api/v1
